{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System.Net.Http.HttpClient": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Data Source=mythra.db;Cache=Shared;Foreign Keys=true;"
  },
  "Cors": {
    "Origins": [
      "http://localhost:3000",
      "http://127.0.0.1:3000"
    ]
  },
  "Jwt": {
    "Issuer": "mythra",
    "Audience": "mythra-clients",
    "Secret": "",
    "AccessTokenMinutes": 30,
    "RefreshTokenDays": 30
  },
  "Ffmpeg": {
    "FfmpegPath": "ffmpeg",
    "FfprobePath": "ffprobe",
    "DefaultSegmentSeconds": 6,
    "DefaultListSize": 0,
    "DefaultPreset": "veryfast",
    "DefaultCrf": "22",
    "ProbeTimeoutSeconds": 30
  },
  "ExternalProviders": {
    "VidsrcEnabled": true,
    "VidsrcBaseUrl": "https://vidsrc.to/embed",
    "ConsumetEnabled": false,
    "ConsumetBaseUrl": "https://api.consumet.org",
    "ArchiveOrgEnabled": true,
    "ArchiveOrgBaseUrl": "https://archive.org",
    "GutendexEnabled": true,
    "GutendexBaseUrl": "https://gutendex.com",
    "LibriVoxEnabled": true,
    "LibriVoxBaseUrl": "https://librivox.org/api/feed",
    "MangaDexEnabled": true,
    "MangaDexBaseUrl": "https://api.mangadex.org",
    "MangaDexRateLimit": 5
  },
  "Metadata": {
    "TmdbApiKey": "",
    "TmdbBaseUrl": "https://api.themoviedb.org/3",
    "TmdbImageBaseUrl": "https://image.tmdb.org/t/p/original",
    "MusicBrainzBaseUrl": "https://musicbrainz.org/ws/2",
    "MusicBrainzUserAgent": "Mythra/0.1 (https://mythra.local)",
    "AniListBaseUrl": "https://graphql.anilist.co",
    "GoogleBooksBaseUrl": "https://www.googleapis.com/books/v1"
  }
}
